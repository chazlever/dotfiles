#!/bin/bash
#
# Bootstrap a new machine with dotfiles.
#
# Initializes git submodules, sets up gitconfig, symlinks dotfiles,
# and runs per-topic installers.

echo ''
echo '      _       _    __ _ _           '
echo '     | |     | |  / _(_) |          '
echo '   __| | ___ | |_| |_ _| | ___  ___ '
echo '  / _` |/ _ \| __|  _| | |/ _ \/ __|'
# shellcheck disable=SC1003
echo ' | (_| | (_) | |_| | | | |  __/\__ \'
echo '  \__,_|\___/ \__|_| |_|_|\___||___/'
echo ''

DOTFILES="$(cd "$(dirname "$0")/.." && pwd)"

# shellcheck source=script/functions
. "$DOTFILES/script/functions"

# --- Git submodules ---

setup_submodules () {
  info 'initializing git submodules'
  git -C "$DOTFILES" submodule update --init --recursive
  success 'submodules initialized'
}

# --- Gitconfig ---

setup_gitconfig () {
  local local_gitconfig="$DOTFILES/git/gitconfig.local.symlink"

  if [ -f "$local_gitconfig" ]; then
    success 'gitconfig.local already configured'
    return
  fi

  info 'setting up gitconfig'

  user 'What is your git author name?'
  read -r git_authorname < /dev/tty
  user 'What is your git author email?'
  read -r git_authoremail < /dev/tty
  user 'What is your GitHub username?'
  read -r git_githubuser < /dev/tty

  sed -e "s/AUTHORNAME/$git_authorname/g" \
      -e "s/AUTHOREMAIL/$git_authoremail/g" \
      -e "s/GITHUBUSER/$git_githubuser/g" \
      "$DOTFILES/git/gitconfig.local.example" > "$local_gitconfig"

  success 'gitconfig.local created'
}

# --- Linking ---

link_file () {
  local src="$1" dst="$2"

  local overwrite=false
  local backup=false
  local skip=false

  if [ -f "$dst" ] || [ -d "$dst" ] || [ -L "$dst" ]; then

    if [ "$overwrite_all" = "false" ] && [ "$backup_all" = "false" ] && [ "$skip_all" = "false" ]; then

      local currentSrc
      currentSrc="$(readlink "$dst" 2>/dev/null || true)"

      if [ "$currentSrc" = "$src" ]; then
        skip=true
        success "identical $dst"
      else
        info "File already exists: $dst ($(basename "$src")), what do you want to do?"
        user "[s]kip, [S]kip all, [o]verwrite, [O]verwrite all, [b]ackup, [B]ackup all?"
        read -r -n 1 action < /dev/tty
        echo ''

        case "$action" in
          o )
            overwrite=true;;
          O )
            overwrite_all=true;;
          b )
            backup=true;;
          B )
            backup_all=true;;
          s )
            skip=true;;
          S )
            skip_all=true;;
          * )
            ;;
        esac
      fi
    fi

    if [ "$overwrite_all" = "true" ]; then
      overwrite=true
    fi
    if [ "$backup_all" = "true" ]; then
      backup=true
    fi
    if [ "$skip_all" = "true" ]; then
      skip=true
    fi

    if [ "$overwrite" = "true" ]; then
      rm -rf "$dst"
      success "removed $dst"
    fi

    if [ "$backup" = "true" ]; then
      mv "$dst" "${dst}.backup"
      success "moved $dst to ${dst}.backup"
    fi

    if [ "$skip" = "true" ]; then
      success "skipped $src"
    fi
  fi

  if [ "$skip" != "true" ]; then
    local parent
    parent=$(dirname "$dst")
    if [ ! -d "$parent" ]; then
      mkdir -p "$parent"
    fi

    ln -sn "$src" "$dst"
    success "linked $src to $dst"
  fi
}

install_dotfiles () {
  info 'installing dotfiles'

  overwrite_all=false
  backup_all=false
  skip_all=false

  # Link *.symlink files to ~/.<basename>
  while read -r src; do
    dst="$HOME/.$(basename "${src%.*}")"
    link_file "$src" "$dst"
  done < <(find "$DOTFILES" -maxdepth 3 -name '*.symlink' -not -path '*/\.git/*')

  # Link *.config files to ~/.config/<basename>
  while read -r src; do
    dst="$HOME/.config/$(basename "${src%.*}")"
    link_file "$src" "$dst"
  done < <(find "$DOTFILES" -maxdepth 3 -name '*.config' -not -path '*/\.git/*')

}

# --- Main ---

echo ''
setup_submodules
setup_gitconfig
install_dotfiles

# Run per-topic installers
"$DOTFILES/script/install"

echo ''
success 'all done!'
