[include]
	path = ~/.gitconfig.local
[alias]
	last = cat-file commit HEAD
	graph = log --graph
[color]
	ui = true
[core]
	excludesfile = ~/.gitignore
[format]
	pretty = %C(yellow)%h%Creset %s %C(red)(%an, %cr)%Creset
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
